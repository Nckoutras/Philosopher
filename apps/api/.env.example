# ── App ───────────────────────────────────────────────────────────
APP_NAME=Philosopher
ENV=development
DEBUG=true
BASE_URL=http://localhost:3000
API_SECRET_KEY=change-me-32-chars-minimum

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://philosopher:philosopher@localhost:5432/philosopher

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-32-chars-minimum
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Anthropic ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MEMORY_MODEL=claude-haiku-4-5-20251001

# ── OpenAI (embeddings) ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@philosopher.app

# ── Analytics ────────────────────────────────────────────────────
POSTHOG_API_KEY=phc_...
